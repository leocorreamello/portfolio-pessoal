VITE_CONTENT_SOURCE=local
# Set to "supabase" to enable admin persistence
# VITE_CONTENT_SOURCE=supabase

# Supabase project settings
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Owner allowlist (comma-separated). If empty, any authenticated email can enter admin.
VITE_ADMIN_EMAILS=

# Content storage table config
VITE_SUPABASE_CONTENT_TABLE=portfolio_content
VITE_SUPABASE_CONTENT_ROW_ID=1

# Storage bucket for resume uploads
VITE_SUPABASE_RESUME_BUCKET=resume-files
